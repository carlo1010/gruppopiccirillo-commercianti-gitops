{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["tenant", "apps"],
  "properties": {
    "tenant": {
      "type": "object",
      "required": [
        "tenantId",
        "slug",
        "displayName",
        "specVersion",
        "namespace",
        "releaseChannel",
        "themePreset",
        "primaryDomain",
        "domains",
        "tls",
        "database",
        "storage"
      ],
      "properties": {
        "tenantId": {
          "type": "string",
          "format": "uuid"
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9](?:[a-z0-9-]{1,38}[a-z0-9])?$"
        },
        "displayName": {
          "type": "string",
          "minLength": 3,
          "maxLength": 120
        },
        "specVersion": {
          "type": "string"
        },
        "namespace": {
          "type": "string",
          "pattern": "^[a-z0-9]([-a-z0-9]{0,61}[a-z0-9])?$"
        },
        "releaseChannel": {
          "type": "string",
          "enum": ["dev", "staging", "stable"]
        },
        "themePreset": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "primaryDomain": {
          "type": "string",
          "format": "hostname"
        },
        "domains": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "format": "hostname"
          }
        },
        "database": {
          "type": "object",
          "required": [
            "engine",
            "host",
            "port",
            "databaseName",
            "credentialsSecretName"
          ],
          "properties": {
            "engine": {
              "type": "string",
              "enum": ["postgres", "mysql"]
            },
            "host": {
              "type": "string"
            },
            "port": {
              "type": "integer",
              "minimum": 1
            },
            "databaseName": {
              "type": "string",
              "minLength": 1
            },
            "credentialsRef": {
              "type": "string"
            },
            "credentialsSecretName": {
              "type": "string",
              "minLength": 1
            },
            "migrationStrategy": {
              "type": "string",
              "enum": ["bootstrap", "manual", "job"]
            }
          }
        },
        "storage": {
          "type": "object",
          "required": [
            "provider",
            "bucket",
            "prefix"
          ],
          "properties": {
            "provider": {
              "type": "string",
              "enum": ["s3", "r2", "local-pv"]
            },
            "bucket": {
              "type": "string",
              "minLength": 1
            },
            "prefix": {
              "type": "string"
            },
            "credentialsRef": {
              "type": "string"
            },
            "credentialsSecretName": {
              "type": "string"
            }
          }
        },
        "backup": {
          "type": "object",
          "required": ["enabled", "provider", "schedule", "retentionDays"],
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "provider": {
              "type": "string",
              "enum": ["s3", "r2", "snapshot"]
            },
            "schedule": {
              "type": "string",
              "minLength": 1
            },
            "retentionDays": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "secretRefs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "provider", "ref"],
            "properties": {
              "name": {
                "type": "string"
              },
              "provider": {
                "type": "string",
                "enum": ["vault", "external-secret", "kubernetes-secret"]
              },
              "ref": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "apps": {
      "type": "object",
      "required": ["frontend", "cms"]
    }
  }
}
